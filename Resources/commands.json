{
    "version": 1,
    "command_sets": [
        {
            "id": 1000,
            "label": "OsintgramCXX core",
            "description": "Command set for managing OsintgramCXX core functionalities",
            "author": "BC100Dev",
            "lib": {
                "linux:x64": "libOsintgramCXX-core.so",
                "linux:arm64": "libOsintgramCXX-core.so",
                "android:x64": "libOsintgramCXX-core.so",
                "android:arm64": "libOsintgramCXX-core.so",
                "windows:x64": "OsintgramCXX-core.dll"
            },
            "handlers": {
                "OnLoad": "plugin_handle_start",
                "OnStop": "plugin_handle_stop",
                "OnCommandExecStart": "plugin_cmd_exec_start",
                "OnCommandExecFinish": "plugin_cmd_exec_finish"
            },
            "cmd_list": [
                {
                    "cmd": "env",
                    "description": "Prints out the environment variables",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "cachectl",
                    "description": "Manages OsintgramCXX and Instagram Cache (involves Cookies & Auth)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "userctl",
                    "description": "Manages Instagram Accounts (login, logout, status, whoami)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "sessionctl",
                    "description": "Manages Instagram Target Sessions (target, current, clear, search)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "net",
                    "description": "Manage network configurations",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "dsi",
                    "description": "Manages the Device Spoofing Information (DSI) for the effective Instagram APIs",
                    "exec_symbol": "cmd_handle"
                }
            ]
        },
        {
            "id": 1001,
            "label": "OsintgramCXX Instagram Interactives",
            "description": "Command Set for Instagram Interaction and OSINT",
            "author": "BC100Dev",
            "lib": {
                "linux:x64": "libOsintgramCXX-interactive.so",
                "linux:arm64": "libOsintgramCXX-interactive.so",
                "android:x64": "libOsintgramCXX-interactive.so",
                "android:arm64": "libOsintgramCXX-interactive.so",
                "windows:x64": "OsintgramCXX-interactive.dll"
            },
            "cmd_list": [
                {
                    "cmd": "addrs",
                    "description": "Get all registered addresses/locations from target's geotagged posts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "bio",
                    "description": "Show the target's biography and external URL",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "captions",
                    "description": "Get captions from the target's posts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "comments",
                    "description": "Returns the total number of comments on each post",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "email",
                    "description": "Show the target's public email and phone number",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "followers",
                    "description": "Get ALL of the target's followers (optionally: followers <limit>)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "followings",
                    "description": "Get ALL accounts the target is following (optionally: followings <limit>)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "fwercount",
                    "description": "Show follower/following/post count and follow ratio",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "hashtags",
                    "description": "Return all hashtags used by the target with frequency counts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "info",
                    "description": "Show all information about the target's account",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "likes",
                    "description": "Returns total like counts for each post and overall average",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "likers",
                    "description": "Show who liked the target's posts and identify top likers",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "mediatype",
                    "description": "Shows the count of photos, videos, and carousels shared by the target",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "mutual",
                    "description": "Find mutual followers/following and accounts not followed back",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "photodesc",
                    "description": "Detailed description of each post (type, date, likes, location, tags)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "photos",
                    "description": "Get download URLs for the target's photos",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "pfp",
                    "description": "Get the profile picture URL (attempts HD version if available)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "post.comments",
                    "description": "Show all comments on each of the target's posts with usernames and timestamps",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "stories",
                    "description": "Get URLs for the target's currently active stories",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "tagged",
                    "description": "Returns a list of users tagged by the target in their posts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "u.comments",
                    "description": "Find commenters on target's posts + target's comments on tagged posts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "u.tagged",
                    "description": "Find all posts where others tagged the target (photo tags)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "u.activity",
                    "description": "Scan related accounts for target's comments and likes (cross-account activity)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "u.mentions",
                    "description": "Find @target mentions in captions and comments across related accounts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "fans",
                    "description": "Engagement analysis: rank who likes and comments most on target's posts",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "shared",
                    "description": "Find shared connections (shared / shared <user> / shared <user1> <user2>)",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "shared.activity",
                    "description": "Scan shared followings (public + private you follow) for comments/likes by two targets",
                    "exec_symbol": "cmd_handle"
                },
                {
                    "cmd": "shared.comments",
                    "description": "Find posts from shared followings where both targets commented, with timestamps and links",
                    "exec_symbol": "cmd_handle"
                }
            ]
        }
    ]
}
